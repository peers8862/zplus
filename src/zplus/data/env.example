# Copy to `.env` (gitignored) and set the real site password.
# `zplus build` / `zplus deploy` load `.env` automatically, so every protected
# build uses it.
#
#   cp .env.example .env && $EDITOR .env
#   zplus build
#
# The password lives ONLY in `.env` (never committed) and in each reader's browser.
SITE_PASSWORD=change-me
